{
  "name": "my-launcher",
  "version": "1.0.0",
  "description": "Electron launcher with screen privacy filter",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --dir",
    "dist": "electron-builder --win",
    "build:mac": "electron-builder --mac --dir",
    "dist:mac": "electron-builder --mac"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.vestige.mylauncher",
    "productName": "graber",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "**/*",
      "build/icon.*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
